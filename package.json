{
  "name": "waku-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @waku/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx,md,json}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx,md,json}\" --cache"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp", "@resvg/resvg-js", "esbuild", "unrs-resolver"]
  }
}
