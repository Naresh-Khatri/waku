{
  "name": "@waku/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "dotenv -e ../../.env -- next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:push": "dotenv -e ../../.env -- drizzle-kit push",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "db:seed": "tsx --env-file=../../.env scripts/seed-system-templates.ts",
    "dev": "dotenv -e ../../.env -- next dev --turbo",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "pnpm build && pnpm start",
    "start": "dotenv -e ../../.env -- next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.38",
    "@auth/drizzle-adapter": "^1.7.2",
    "@aws-sdk/client-s3": "^3.1043.0",
    "@aws-sdk/s3-request-presigner": "^3.1043.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@waku/db": "workspace:*",
    "@waku/ir": "workspace:*",
    "@waku/renderer": "workspace:*",
    "@waku/templates": "workspace:*",
    "ai": "^6.0.175",
    "better-auth": "^1.3",
    "drizzle-orm": "^0.41.0",
    "next": "^15.2.3",
    "postgres": "^3.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.30.5",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "eslint-plugin-drizzle": "^0.2.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  }
}
