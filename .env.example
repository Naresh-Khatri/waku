# Copy to .env and fill in. Validated at startup by @t3-oss/env-nextjs.

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:5000"
BETTER_AUTH_GITHUB_CLIENT_ID=""
BETTER_AUTH_GITHUB_CLIENT_SECRET=""
BETTER_AUTH_GOOGLE_CLIENT_ID=""
BETTER_AUTH_GOOGLE_CLIENT_SECRET=""

# Database
DATABASE_URL="postgresql://postgres:password@localhost:6666/waku"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# Render service base URL exposed to the web client
NEXT_PUBLIC_RENDER_BASE_URL=http://localhost:5001

# Render app limits
FREE_DAILY_LIMIT=1000

# AI (Groq) — leave GROQ_API_KEY blank to run in stub mode
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
